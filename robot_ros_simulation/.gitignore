# ROS 2 / colcon build outputs
/build/
/install/
/log/

# Accidental nested colcon outputs inside packages
src/**/build/
src/**/install/
src/**/log/

# colcon metadata / ignore markers in generated dirs
**/COLCON_IGNORE

# Python cache / bytecode
__pycache__/
*.py[cod]
*$py.class

# Python packaging
*.egg-info/
.eggs/
dist/
*.egg
pip-wheel-metadata/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.cache/

# Virtual environments
.venv/
venv/
env/
ENV/

# ROS logs / bags
*.bag
*.bag.active
*.db3
*.mcap

# RViz generated configs / temporary files
*.rviz~
.rviz2/

# Gazebo / simulation generated files
.gazebo/
*.log

# OS files
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# CMake / native build leftovers
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
compile_commands.json

# Pixi / Conda local env artifacts
.pixi/envs/
.conda/
src/robot_description/fixed/*
